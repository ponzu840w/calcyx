{
  "version": 6,
  "configurePresets": [
    {
      "name": "base-unix",
      "hidden": true,
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "unix",
      "displayName": "Unix Release (macOS / Linux)",
      "inherits": "base-unix"
    },
    {
      "name": "unix-debug",
      "displayName": "Unix Debug (macOS / Linux)",
      "inherits": "base-unix",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_FLAGS_DEBUG":   "-g -fsanitize=address,leak -fno-omit-frame-pointer",
        "CMAKE_CXX_FLAGS_DEBUG": "-g -fsanitize=address,leak -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS_DEBUG": "-fsanitize=address,leak"
      }
    },
    {
      "name": "base-win",
      "hidden": true,
      "binaryDir": "${sourceDir}/build-win",
      "toolchainFile": "${sourceDir}/cmake/toolchain-win.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_FLAGS": "-g",
        "CMAKE_CXX_FLAGS": "-g"
      }
    },
    {
      "name": "win",
      "displayName": "Windows Release (MinGW-w64 cross)",
      "inherits": "base-win"
    },
    {
      "name": "win-debug",
      "displayName": "Windows Debug (MinGW-w64 cross)",
      "inherits": "base-win",
      "binaryDir": "${sourceDir}/build-win-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "web",
      "displayName": "Web (Emscripten / WebAssembly)",
      "binaryDir": "${sourceDir}/build-web",
      "toolchainFile": "${sourceDir}/cmake/toolchain-emscripten.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    { "name": "unix",       "configurePreset": "unix" },
    { "name": "unix-debug", "configurePreset": "unix-debug" },
    { "name": "win",        "configurePreset": "win" },
    { "name": "win-debug",  "configurePreset": "win-debug" },
    { "name": "web",        "configurePreset": "web" }
  ],
  "testPresets": [
    {
      "name": "unix",
      "configurePreset": "unix",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "unix-debug",
      "configurePreset": "unix-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "unix-headless",
      "configurePreset": "unix",
      "output": { "outputOnFailure": true },
      "filter": { "exclude": { "label": "gui" } }
    },
    {
      "name": "win-headless",
      "configurePreset": "win",
      "output": { "outputOnFailure": true },
      "filter": { "exclude": { "label": "gui" } }
    },
    {
      "name": "web",
      "configurePreset": "web",
      "output": { "outputOnFailure": true }
    }
  ],
  "packagePresets": [
    { "name": "unix", "configurePreset": "unix" },
    { "name": "win",  "configurePreset": "win" },
    { "name": "web",  "configurePreset": "web" }
  ]
}
